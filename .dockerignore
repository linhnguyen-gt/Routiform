# VCS
.git
**/.git

# Editor
.vscode
**/.vscode

# Dependencies and build output.
# The `**/` forms matter: a bare `node_modules` matches ONLY the repo root, so without these the
# vendored open-webui/node_modules (~1.3GB) and open-webui/build get shipped into the build
# context on every `docker build`.
node_modules
**/node_modules
.next
out
build
**/build
**/.svelte-kit
dist
coverage

# The chat SPA is rebuilt inside the image (Dockerfile runs `npm run owui:build`), so the local
# 66MB copy is dead weight in the context — and a stale one would be overwritten anyway.
public/owui

# Runtime data and logs
data
logs

# Local env files (inject at runtime via --env-file or -e)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Test suites
tests
test-results
playwright-report
blob-report

# Documentation (not needed in container)
docs
*.md
!README.md

# VS Code extension (separate project)
vscode-extension

# Build artifacts
*.tgz
*.AppImage
*.deb
*.rpm

# Package manager lock (bun)
bun.lock

# Agent config
.agents
.gemini

# Misc
llm.txt
images
clipr
routiformCloud
routiformSite
